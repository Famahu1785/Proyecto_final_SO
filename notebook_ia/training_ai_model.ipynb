      "outputs": [],
      "source": [
        "import math\n",
        "import random\n",
        "\n",
        "# Cálculos pesados de CPU\n",
        "def estres_cpu():\n",
        "    resultados = []\n",
        "    # Puede modificar el rango para generar mas cilcos\n",
        "    for i in range(10000):\n",
        "        resultado = sum(math.sin(x) * math.cos(x) for x in range(100))\n",
        "        resultados.append(resultado)\n",
        "    return resultados\n",
        "\n",
        "estres_cpu()"
      ]
    }
